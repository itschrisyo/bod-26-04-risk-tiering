  "api_response_structure": {
    "top_level_fields": {
      "items": "Array of finding objects (each with the fields above)",
      "total": "Total number of findings matching the query",
      "offset": "Pagination offset",
      "limit": "Maximum results returned per page"
    }
  },
  "summary": {
    "total_fields": 44,
    "key_findings": [
      "CVE IDs are in the 'finding_cves' field as an ARRAY of strings",
      "Asset information is available via asset_id, asset_name, and asset_class",
      "First detection date is in 'first_observed_at' field (ISO 8601 date)",
      "NO direct exposure/internet-facing fields in findings API",
      "NO KEV-related fields in findings API - must cross-reference externally",
      "Exposure data requires separate Assets API query using asset_id"
    ]
  }
}
