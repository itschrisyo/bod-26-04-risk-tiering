  "example_workflows": {
    "get_bod_26_04_data": {
      "description": "Retrieve BOD 26-04 relevant data: Critical vulnerabilities with KEV dates on assets with ACR scores",
      "steps": [
        {
          "step": 1,
          "action": "GET /workbenches/vulnerabilities",
          "parameters": "filter by severity=Critical",
          "extract": ["plugin_id", "plugin_name", "count", "vpr_score"]
        },
        {
          "step": 2,
          "action": "For each plugin_id, GET /plugins/plugin/{plugin_id}",
          "extract": ["cisa-known-exploited attribute from attributes array"],
          "filter": "Only keep plugins where cisa-known-exploited exists"
        },
        {
          "step": 3,
          "action": "GET /assets",
          "extract": ["id", "acr_score", "exposure_score", "ipv4", "fqdn", "operating_system"],
          "notes": "All assets with their ACR scores"
        },
        {
          "step": 4,
          "action": "For each asset, GET /workbenches/assets/{asset_id}/vulnerabilities",
          "match": "Cross-reference asset vulnerabilities with KEV plugin list from step 2"
        },
        {
          "step": 5,
          "action": "Output combined data",
          "format": {
            "asset_id": "string",
            "asset_ipv4": "string",
            "asset_fqdn": "string",
            "acr_score": "integer",
            "exposure_score": "integer",
            "vulnerabilities": [
              {
                "plugin_id": "integer",
                "plugin_name": "string",
                "cisa_kev_date": "YYYY/MM/DD",
                "cvss3_score": "float",
                "first_detected": "timestamp",
                "last_detected": "timestamp"
              }
            ]
          }
        }
      ]
    }
  },

