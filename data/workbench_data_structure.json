  "api_endpoints": {
    "list_assets": {
      "endpoint": "/assets",
      "method": "GET",
      "returns": "List of assets with acr_score, exposure_score, and other metadata",
      "fields_of_interest": [
        "id",
        "acr_score",
        "acr_drivers",
        "exposure_score",
