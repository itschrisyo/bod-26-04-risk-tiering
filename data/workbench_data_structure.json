      "method": "GET",
      "returns": "Detailed asset information including acr_score_v3"
    },
    "list_vulnerabilities": {
      "endpoint": "/workbenches/vulnerabilities",
      "method": "GET",
      "parameters": {
        "filter.0.filter": "severity",
